<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_project_study_list" model="ir.ui.view">
        <field name="name">project.study.list</field>
        <field name="model">project.study</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="user_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="date_deadline"/>
                <field name="parent_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_project_study_form" model="ir.ui.view">
        <field name="name">project.study.form</field>
        <field name="model">project.study</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="tên task"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="parent_id"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="date_deadline"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_project_study_graph" model="ir.ui.view">
        <field name="name">project.study.graph</field>
        <field name="model">project.study</field>
        <field name="arch" type="xml">
            <graph string="Thống kê Task" type="bar">
                <field name="user_id" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_project_study" model="ir.actions.act_window">
        <field name="name">Study</field>
        <field name="res_model">project.study</field>
        <field name="view_mode">list,form,graph</field>
    </record>
</odoo>