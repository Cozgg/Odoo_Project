<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_project_study_list" model="ir.ui.view">
        <field name="name">project.study.list</field>
        <field name="model">project.study</field>
        <field name="arch" type="xml">
            <list string="Study Tasks">
                <field name="name"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="date_deadline"/>
                <field name="parent_id"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'todo'"
                       decoration-warning="state == 'inprogress'"
                       decoration-primary="state == 'review'"
                       decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_project_study_form" model="ir.ui.view">
        <field name="name">project.study.form</field>
        <field name="model">project.study</field>
        <field name="arch" type="xml">
            <form string="Project Study">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}" statusbar_visible="todo,inprogress,review,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên nhiệm vụ"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="date_deadline"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_project_study_graph" model="ir.ui.view">
        <field name="name">project.study.graph</field>
        <field name="model">project.study</field>
        <field name="arch" type="xml">
            <graph string="Study Tasks Analysis" type="bar" sample="1">
                <field name="user_id"/>
            </graph>
        </field>
    </record>

    <record id="action_project_study" model="ir.actions.act_window">
        <field name="name">Study</field>
        <field name="res_model">project.study</field>
        <field name="view_mode">list,form,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo task
            </p>
        </field>
    </record>

</odoo>