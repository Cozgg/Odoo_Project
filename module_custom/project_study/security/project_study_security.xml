<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_project_study" model="ir.module.category">
            <field name="name">Project Study</field>
            <field name="sequence">10</field>
        </record>

        <record id="res_groups_privilege_project_study" model="res.groups.privilege">
            <field name="name">Project Study</field>
            <field name="sequence">1</field>
            <field name="category_id" ref="module_category_project_study"/>
        </record>

        <record id="group_project_study_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="res_groups_privilege_project_study"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Chỉ xem được những record do user tạo ra hoặc được Assigned To</field>
        </record>

        <record id="group_project_study_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_project_study"/>
            <field name="implied_ids" eval="[(4, ref('group_project_study_user'))]"/>
            <field name="comment">Xem được tất cả các records của project.study</field>
        </record>
    </data>

    <data noupdate="1">
        <record id="rule_project_study_user" model="ir.rule">
            <field name="name">User Tasks</field>
            <field name="model_id" ref="model_project_study"/>
            <field name="domain_force">['|', ('create_uid', '=', user.id), ('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_project_study_user'))]"/>
        </record>

        <record id="rule_project_study_manager" model="ir.rule">
            <field name="name">All Tasks</field>
            <field name="model_id" ref="model_project_study"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_project_study_manager'))]"/>
        </record>
    </data>
</odoo>